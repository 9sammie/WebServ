http {
    keepalive_timeout 15;
    client_max_body_size 1048576; # 1 MiB

    error_page 404 /errors/404.html;
    error_page 500 /errors/500.html;
    
    server {
        include extra.conf;
        listen 0.0.0.0:8080;
        server_name test_serv_1;

        # 1. Main route for home and menu
        location / {
            root ./html/site1;
            index home.html;
            autoindex off;
            methods GET;
        }

        # 2. NEW: Dedicated route for the dishes subfolder
        # This allows the script to redirect to /dishes/ratatouille.html
        location /dishes {
            root ./html/site1/dishes; # Combined with URI, looks into ./html/site1/dishes/
            methods GET;
            autoindex off;
        }

        # 3. UPDATED: CGI route for the random plate script
        # Adjusted root to match your folder structure
        location /cgi-bin {
            root ./html/site1/cgi-bin; # The script is at ./html/site1/cgi-bin/random_plate.py
            methods GET;
            cgi_ext .py;
            cgi_path /usr/bin/python3;
        }

        # --- Other existing routes ---

        location /old-page {
            return 301 /new-page;
            methods GET;
        }

        location /new-page {
            root ./html/site1;
            index new.html;
            methods GET;
        }
        
        location /srcs {
            root ./srcs;
            autoindex on;
            methods GET;
        }
        
        location /uploads {
            root ./uploads/site1;
            methods POST;
        }
        
        location /files {
            root ./uploads/site1;
            autoindex on;
            methods GET DELETE;
        }
    }
    
    server {
        listen 127.0.0.1:8081;
        server_name test_serv_2;
        
        location / {
            root ./html/site2;
            index home.html;
            methods GET;
        }
    }
}