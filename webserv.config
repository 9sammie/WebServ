http {
	keepalive_timeout 15; #secondes
	client_max_body_size 1048576;    # 1 MiB mebibyte (base 2) 2 puissance 10 = 1024 ; 1 MiB = 1 048 576 octets (= 1024 × 1024)

	error_page 404 /errors/404.html;
	error_page 500 /errors/500.html;
	
	server {
		include extra.conf;
		listen 127.0.0.1:8080;
		server_name test_serv_1;

		location / {
			root ./html/site1; # chemin relatif, à adapter ensuite
            
			# Exemple :
			#   GET /assets/logo.png
			#	va chercher le fichier : ./html/site1/assets/logo.png
			
			index home.html;
			# Si l’URL demandée correspond à un dossier, on sert ce fichier par défaut.
			# Exemple :
			#   GET /
			#	sert : ./html/site1/home.html
			#
			# Exemple :
			#   GET /blog/      (si ./html/site1/blog/ existe)
			#	sert : ./html/site1/blog/home.html   (si le fichier existe)
			
			autoindex off;
			# Si l’URL pointe vers un dossier et que le fichier 'index' n’existe pas,
			# alors on NE génère PAS la liste des fichiers du dossier.
			# (il faudra générer une page d'erreur ? : 403 Forbidden ou 404 Not Found)
            
			methods GET;
			# Seule la méthode HTTP GET est autorisée sur cette route.
			# Exemple :
			#   POST / ou DELETE /	doivent répondre 405 Method Not Allowed    

		}

		# Rediriger /old-page vers /new-page
		location /old-page {
			return 301 /new-page;
			methods GET;
		}

		location /new-page {
			root ./html/site1;
			index new.html;
			methods GET;
		}
		
		location /srcs {
		# Cette route s’applique à toutes les URLs qui commencent par "/srcs"
		# Exemple : /srcs, /srcs/, /srcs/main.cpp, /srcs/utils/file.cpp
		
			root ./srcs;
			autoindex on;
			# Si l’URL correspond à un dossier (ex: GET /srcs/),
			# et qu’aucun fichier index n’est défini / trouvé,
			# le serveur génère une page HTML qui liste le contenu du dossier
			# (noms de fichiers + liens), comme un “listing” de répertoire
			
			methods GET;
		}
        
		location /uploads {
			root ./uploads/site1;    # stockage des fichiers uploadés
			methods POST;
		}
		
		location /files {
			root ./uploads/site1;
			# Dossier sur le disque où sont stockés les fichiers uploadés.
			# Avec la règle "on enlève le préfixe /files de l'URL", on mappe :
			#
			#   GET /files/a.txt
			#	suffix = "/a.txt"
			#	chemin disque = ./uploads/site1/a.txt
			
			autoindex on;
            
			methods GET DELETE;
			# Autorise :
			# - GET : télécharger/lire un fichier uploadé
			# - DELETE : supprimer un fichier uploadé
			#
			# Exemples :
			#   DELETE /files/a.txt  → supprime ./uploads/site1/a.txt (si existe)
			#   POST /files/a.txt    → doit répondre 405 Method Not Allowed
		}
        
		location /cgi {
			root ./cgi;
			methods GET POST;
			cgi_ext .py;
			cgi_path /usr/bin/python3;
		}
	}
    
	server {
		listen 127.0.0.1:8081;
		server_name test_serv_2;
		
		location / {
			root ./html/site2;
			index home.html;
			methods GET;
		}
	}
}
